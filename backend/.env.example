# Required in production
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DJANGO_DEBUG=False

# Comma-separated hostnames (no scheme)
DJANGO_ALLOWED_HOSTS=ai-meal-planner-backend-tud7.onrender.com

# Comma-separated full origins (scheme required)
DJANGO_CSRF_TRUSTED_ORIGINS=https://ai-meal-planner-backend-tud7.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=https://ai-meal-planner-backend-tud7.onrender.com
DJANGO_CORS_ALLOW_CREDENTIALS=False

# Security
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# PostgreSQL (production recommended)
# Render Postgres can populate DATABASE_URL automatically if linked to the web service.
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Or use separate POSTGRES_* values.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
